<!DOCTYPE html>
<html lang="km">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>វិក្កយបត្រ / Invoice</title>
  <link href="https://fonts.googleapis.com/css2?family=Hanuman:wght@400;700&family=Battambang:wght@400;700&family=Moul&display=swap" rel="stylesheet" />
  <style>
    /* ── Reset & Base ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #d0d5dd;
      font-family: 'Hanuman', 'Battambang', serif;
      font-size: 12px;
      color: #1a1a1a;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 24px 0 48px;
    }

    /* ── Print Button Bar ── */
    #toolbar {
      width: 210mm;
      max-width: 100%;
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      margin-bottom: 14px;
    }
    #toolbar button {
      padding: 9px 22px;
      border: none;
      border-radius: 6px;
      font-size: 13px;
      font-family: inherit;
      cursor: pointer;
      font-weight: 600;
      transition: background 0.2s, transform 0.1s;
    }
    #toolbar button:active { transform: scale(0.97); }
    #btn-print  { background: #1a56c4; color: #fff; }
    #btn-print:hover { background: #1444a8; }
    #btn-download { background: #fff; color: #1a56c4; border: 2px solid #1a56c4; }
    #btn-download:hover { background: #eef3ff; }

    /* ── A4 Paper ── */
    #paper {
      width: 210mm;
      min-height: 297mm;
      background: #fff;
      box-shadow: 0 4px 32px rgba(0,0,0,0.18);
      padding: 14mm 14mm 12mm;
      position: relative;
    }

    /* ── Header / Letterhead (image-based) ── */
    .letterhead {
      border-bottom: 2.5px solid #1a56c4;
      padding-bottom: 10px;
      margin-bottom: 12px;
      overflow: hidden;
      transition: max-height 0.35s ease, opacity 0.35s ease,
                  padding 0.35s ease, margin 0.35s ease;
      max-height: 300px;
      opacity: 1;
    }
    .letterhead.hidden {
      max-height: 0;
      opacity: 0;
      padding-bottom: 0;
      margin-bottom: 0;
      border-bottom-color: transparent;
    }
    .letterhead img {
      display: block;
      width: 100%;
      max-height: 260px;
      object-fit: contain;
      object-position: center;
    }
    .letterhead .lh-fallback {
      text-align: center;
      padding: 8px 0 4px;
    }
    .letterhead .lh-fallback .org-title {
      font-size: 22px;
      font-weight: 700;
      font-family: 'Moul', 'Hanuman', serif;
      color: #1a3a8f;
      line-height: 1.4;
    }
    .letterhead .lh-fallback .org-sub {
      font-size: 11.5px;
      color: #1a3a8f;
      font-weight: 600;
      margin-top: 3px;
    }

    /* ── Invoice Title ── */
    .invoice-title {
      text-align: center;
      font-size: 16px;
      font-weight: 700;
      letter-spacing: 1px;
      margin: 10px 0 12px;
      color: #1a1a1a;
    }

    /* ── Meta Grid ── */
    .meta-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4px 20px;
      margin-bottom: 14px;
      font-size: 11.5px;
    }
    .meta-grid .meta-row {
      display: flex;
      gap: 4px;
    }
    .meta-label { font-weight: 600; white-space: nowrap; }
    .meta-value { color: #333; }

    /* ── Table ── */
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 11px;
      margin-bottom: 0;
    }
    th, td {
      border: 1px solid #b0b8cc;
      padding: 5px 7px;
      vertical-align: middle;
    }
    thead th {
      background: #e8edf7;
      font-weight: 700;
      text-align: center;
      color: #1a3a8f;
      font-size: 11px;
    }
    tbody td { color: #222; }
    .col-no   { width: 28px;  text-align: center; }
    .col-desc { min-width: 95px; }
    .col-qty  { width: 78px;  text-align: center; }
    .col-unit { width: 73px;  text-align: center; }
    .col-price{ width: 76px;  text-align: right; }
    .col-total{ width: 76px;  text-align: right; }

    .section-header td {
      background: #ccd4ea;
      font-weight: 700;
      font-size: 11px;
      color: #1a3a8f;
      padding: 5px 7px;
    }

    /* ── Footer Area ── */
    .footer-area {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 0;
      border: 1px solid #b0b8cc;
      border-top: none;
      margin-top: 0;
    }
    .notes-cell {
      padding: 8px 10px;
      border-right: 1px solid #b0b8cc;
      font-size: 11px;
    }
    .notes-cell .notes-title { font-weight: 700; color: #1a3a8f; margin-bottom: 4px; }
    .totals-table {
      width: 240px;
      border-collapse: collapse;
      font-size: 11px;
    }
    .totals-table td {
      border: none;
      border-bottom: 1px solid #d8dde8;
      padding: 5px 10px;
    }
    .totals-table tr:last-child td { border-bottom: none; }
    .totals-table .t-label { text-align: right; font-weight: 600; color: #444; white-space: nowrap; }
    .totals-table .t-value { text-align: right; font-weight: 600; }
    .totals-table .grand-row td { background: #1a3a8f; color: #fff; font-weight: 700; font-size: 12px; }

    /* ── Signature Row ── */
    .sig-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      margin-top: 60px;
      gap: 20px;
    }
    .sig-box { text-align: center; }
    .sig-box .sig-line {
      border-top: 1px solid #888;
      margin: 40px 20px 6px;
    }
    .sig-box .sig-label { font-size: 10.5px; color: #555; font-weight: 600; }

    /* ── Print Styles ── */
    @media print {
      body { background: none; padding: 0; }
      #toolbar { display: none; }
      #paper {
        width: 100%; min-height: 0; box-shadow: none;
        padding: 10mm 12mm;
        page-break-after: always;
      }
    }

    /* ── Empty row hint ── */
    .empty-row td { color: #aaa; font-style: italic; text-align: center; }

    /* ── Toggle button ── */
    #btn-toggle-img {
      background: #fff;
      color: #555;
      border: 2px solid #b0b8cc;
    }
    #btn-toggle-img:hover { background: #f4f6fb; border-color: #1a56c4; color: #1a56c4; }
    #btn-toggle-img.img-hidden { color: #aaa; border-color: #ddd; }

    @media print {
      #btn-toggle-img { display: none; }
    }
  </style>
</head>
<body>

<!-- Toolbar -->
<div id="toolbar">
  <button id="btn-toggle-img" onclick="toggleHeaderImage()">🖼 Hide Header</button>
  <button id="btn-download" onclick="window.print()">⬇ Save as PDF</button>
  <button id="btn-print" onclick="window.print()">🖨 Print</button>
</div>

<!-- A4 Paper -->
<div id="paper">

  <!-- Letterhead: full-width header image from URL param, fallback to text -->
  <div class="letterhead" id="letterhead">
    <!-- Populated by JS: image if header_image param present, else text fallback -->
  </div>

  <!-- Invoice Title -->
  <div class="invoice-title">វិក្កយបត្រ / INVOICE</div>

  <!-- Meta Information -->
  <div class="meta-grid">
    <div class="meta-row">
      <span class="meta-label">ឈ្មោះអតិថិជន (Contact Person)&nbsp;:</span>
      <span class="meta-value" id="m-customer"></span>
    </div>
    <div class="meta-row">
      <span class="meta-label">ល.រ វិក្កយបត្រ (Invoice No)&nbsp;:</span>
      <span class="meta-value" id="m-invoice-no"></span>
    </div>
    <div class="meta-row">
      <span class="meta-label">លេខទំនាក់ទំនង (Contact)&nbsp;:</span>
      <span class="meta-value" id="m-phone"></span>
    </div>
    <div class="meta-row">
      <span class="meta-label">ថ្ងៃបរិច្ឆេទកម្មវិធី (Date)&nbsp;:</span>
      <span class="meta-value" id="m-event-date"></span>
    </div>
    <div class="meta-row">
      <span class="meta-label">ទីតាំងកម្មវិធី (Address)&nbsp;:</span>
      <span class="meta-value" id="m-address"></span>
    </div>
    <div class="meta-row">
      <span class="meta-label">គម្រោងកម្មវិធី (Project)&nbsp;:</span>
      <span class="meta-value" id="m-project"></span>
    </div>
  </div>

  <!-- Line Items Table -->
  <table id="invoice-table">
    <thead>
      <tr>
        <th class="col-no">ល.រ<br>No.</th>
        <th class="col-desc">ប្រភេទសេវាកម្ម<br>Service Description</th>
        <th class="col-qty">ចំនួនពេលបម្រើ<br>Shifts/Days</th>
        <th class="col-unit">ចំនួនសេវាកម្ម<br>Unit</th>
        <th class="col-price">តំលៃ<br>Price</th>
        <th class="col-total">សរុប<br>Total</th>
      </tr>
    </thead>
    <tbody id="table-body">
      <!-- Dynamically injected -->
    </tbody>
  </table>

  <!-- Footer: Notes + Totals -->
  <div class="footer-area">
    <div class="notes-cell">
      <div class="notes-title">កំណត់សំគាល់ (Terms &amp; Conditions)</div>
      <div id="m-notes" style="white-space:pre-line;"></div>
    </div>
    <table class="totals-table">
      <tr>
        <td class="t-label">បូកសរុប (Total USD):</td>
        <td class="t-value" id="t-subtotal"></td>
      </tr>
      <tr>
        <td class="t-label">បញ្ចុះតម្លៃ (Discount):</td>
        <td class="t-value" id="t-discount"></td>
      </tr>
      <tr>
        <td class="t-label">បូកកក់ (Deposit USD):</td>
        <td class="t-value" id="t-deposit"></td>
      </tr>
      <tr class="grand-row">
        <td class="t-label">សរុបចុងក្រោយ (Grand Total USD):</td>
        <td class="t-value" id="t-grand"></td>
      </tr>
    </table>
  </div>

  <!-- Signatures -->
  <div class="sig-row">
    <div class="sig-box">
      <div class="sig-line"></div>
      <div class="sig-label">ហត្ថលេខានិងឈ្មោះអតិថិជន</div>
      <div class="sig-label">Customer's Signature &amp; Name</div>
    </div>
    <div class="sig-box">
      <div class="sig-line"></div>
      <div class="sig-label">ហត្ថលេខា និងឈ្មោះអ្នកលក់</div>
      <div class="sig-label">Seller's Signature &amp; Name</div>
    </div>
  </div>

</div><!-- /#paper -->

<script>
  /* ─────────────────────────────────────────────────────────────
     UTILITY: Parse URL parameters
  ───────────────────────────────────────────────────────────── */
  function getParam(key, fallback = '') {
    const params = new URLSearchParams(window.location.search);
    return params.has(key) ? decodeURIComponent(params.get(key)) : fallback;
  }

  /* ─────────────────────────────────────────────────────────────
     HEADER IMAGE — replaces letterhead with dynamic image from
     URL param: header_image=<encoded_url>
     Falls back to text letterhead if no param is present.
  ───────────────────────────────────────────────────────────── */
  const headerImageUrl = getParam('header_image', '');
  const letterhead = document.getElementById('letterhead');
  const toggleBtn  = document.getElementById('btn-toggle-img');

  if (headerImageUrl) {
    // Image mode: render full-width header image
    const img = document.createElement('img');
    img.src = headerImageUrl;
    img.alt = 'Header';
    letterhead.appendChild(img);
  } else {
    // Text fallback when no header_image param
    letterhead.innerHTML = `
      <div class="lh-fallback">
        <div class="org-title">ឧត្តមប្រណិត ពិធីការ</div>
        <div class="org-sub">ជំនាញដឹកនាំសម្របសម្រួលកម្មវិធីមង្គលការ និងកម្មវិធីផ្សេងៗ</div>
        <div class="org-sub">ឧត្តមស្វាមីឧត្តមភរិយា គុណភាពប្រណិតភាព ធ្វើអោយម្ចាស់កម្មវិធីចងចាំគ្រប់ពេល</div>
      </div>`;
  }

  function toggleHeaderImage() {
    const isHidden = letterhead.classList.toggle('hidden');
    toggleBtn.textContent = isHidden ? '🖼 Show Header' : '🖼 Hide Header';
    toggleBtn.classList.toggle('img-hidden', isHidden);
  }

  /* ─────────────────────────────────────────────────────────────
     SECTION CONFIGS
     AppSheet passes line items per section using indexed params:
       section1_item1, section1_qty1, section1_unit1, section1_rate1, section1_amount1
       section2_item1, ... etc.
     OR a JSON string via param "items_json"
  ───────────────────────────────────────────────────────────── */
  const SECTIONS = [
    { key: 'I',   label: 'I. បរិយាយកញ្ចប់ដឹកនាំសម្របសម្រួលក្នុងកម្មវិធី',       prefix: 's1' },
    { key: 'II',  label: 'II. បរិយាយសេវាកម្មបម្រើបដិសណ្ឋាកិច្ចភ្ញៀវកិត្តយស', prefix: 's2' },
    { key: 'III', label: 'III. បរិយាយសេវាកម្មបន្ថែមផ្សេងទៀត',                  prefix: 's3' },
  ];

  /* ─────────────────────────────────────────────────────────────
     FILL HEADER FIELDS
  ───────────────────────────────────────────────────────────── */
  document.getElementById('m-customer').textContent    = getParam('customer');
  document.getElementById('m-invoice-no').textContent  = getParam('invoice_no', getParam('invoice_date'));
  document.getElementById('m-phone').textContent       = getParam('phone_number');
  document.getElementById('m-event-date').textContent  = getParam('event_date');
  document.getElementById('m-address').textContent     = getParam('address');
  document.getElementById('m-project').textContent     = getParam('project');
  document.getElementById('m-notes').textContent       = getParam('notes');

  /* ─────────────────────────────────────────────────────────────
     FILL TOTALS
  ───────────────────────────────────────────────────────────── */
  document.getElementById('t-subtotal').textContent  = getParam('subtotal',   '$0.00');
  document.getElementById('t-discount').textContent  = getParam('discount',   '$0.00');
  document.getElementById('t-deposit').textContent   = getParam('deposit',    '$0.00');
  document.getElementById('t-grand').textContent     = getParam('grand_total','$0.00');

  /* ─────────────────────────────────────────────────────────────
     BUILD LINE ITEM ROWS
     Supports two strategies:
       A) items_json  – a JSON array of objects passed as one param
       B) Indexed URL params per section (s1_name1, s1_qty1 … s3_amount5)
  ───────────────────────────────────────────────────────────── */
  const tbody = document.getElementById('table-body');

  function makeRow(no, name, qty, unit, rate, amount) {
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td class="col-no">${no}</td>
      <td class="col-desc">${name}</td>
      <td class="col-qty">${qty}</td>
      <td class="col-unit">${unit}</td>
      <td class="col-price">${rate}</td>
      <td class="col-total">${amount}</td>`;
    return tr;
  }

  function makeSectionHeader(label) {
    const tr = document.createElement('tr');
    tr.className = 'section-header';
    tr.innerHTML = `<td colspan="6">${label}</td>`;
    return tr;
  }

  function makeEmptyRow() {
    const tr = document.createElement('tr');
    tr.className = 'empty-row';
    tr.innerHTML = `<td colspan="6">— no items —</td>`;
    return tr;
  }

  /* Strategy A: items_json */
  const itemsJson = getParam('items_json', '');
  if (itemsJson) {
    try {
      const data = JSON.parse(itemsJson);
      // data = [ { section: "I", name, qty, unit, rate, amount }, ... ]
      SECTIONS.forEach(sec => {
        tbody.appendChild(makeSectionHeader(sec.label));
        const rows = data.filter(d => (d.section || '').toUpperCase() === sec.key);
        if (rows.length === 0) {
          tbody.appendChild(makeEmptyRow());
        } else {
          rows.forEach((r, i) => tbody.appendChild(makeRow(i + 1, r.name, r.qty, r.unit, r.rate, r.amount)));
        }
      });
    } catch(e) {
      console.error('items_json parse error', e);
    }
  } else {
    /* Strategy B: indexed URL params per section */
    SECTIONS.forEach(sec => {
      tbody.appendChild(makeSectionHeader(sec.label));
      let found = false;
      for (let i = 1; i <= 20; i++) {
        const name = getParam(`${sec.prefix}_name${i}`, '');
        if (!name) break;
        const qty    = getParam(`${sec.prefix}_qty${i}`,    '');
        const unit   = getParam(`${sec.prefix}_unit${i}`,   '');
        const rate   = getParam(`${sec.prefix}_rate${i}`,   '');
        const amount = getParam(`${sec.prefix}_amount${i}`, '');
        tbody.appendChild(makeRow(i, name, qty, unit, rate, amount));
        found = true;
      }
      if (!found) tbody.appendChild(makeEmptyRow());
    });
  }
</script>
</body>
</html>
